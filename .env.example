# MongoDB connection string
MONGODB_URI=mongodb://admin:password123@localhost:27019/luci-ui?authSource=admin

# 32-byte hexadecimal key for AES-256-GCM encryption of user API keys
# Generate one using: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# Secret key for signing JWT tokens
# Generate one using: openssl rand -hex 32
JWT_SECRET=your-secure-jwt-secret-here

# Application environment (local | production)
ENVIRONMENT=local

# Comma-separated list of emails allowed to register/sign up
ALLOWED_EMAILS=admin@luci.app,hi@krishalshah.in
